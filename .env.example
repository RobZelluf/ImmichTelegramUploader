# Copy to .env and fill in. Never commit the real .env.

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=123456:ABC-DEF...

# WHITELIST of Telegram user IDs allowed to upload (comma-separated).
# Anyone not in this list is ignored. Get your numeric ID from @userinfobot.
# If left empty, the bot accepts media from ANYONE who can message it — don't.
ALLOWED_USERS=123456789,987654321

# Immich server reachable from this container (Docker network name or address)
IMMICH_URL=http://immich-server:2283
# Immich API key: Account Settings -> API Keys
IMMICH_API_KEY=your-immich-api-key

# Album every upload is added to (auto-created if missing)
IMMICH_ALBUM="Telegram Bot Uploads"

# --- Optional ---------------------------------------------------------------
# IMMICH_DEVICE_ID=telegram-bot
# LOG_LEVEL=INFO
# Reaction emojis (must be ones Telegram allows bots to use; text fallback
# kicks in if rejected). Defaults: 👍 / 👀 / 👎
# REACT_OK=👍
# REACT_DUPLICATE=👀
# REACT_FAIL=👎
